{
  "name": "simloop",
  "version": "0.1.0",
  "description": "A general-purpose discrete event simulation framework for Node.js",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "example:coffee-shop": "tsx examples/coffee-shop/main.ts"
  },
  "keywords": [
    "simulation",
    "discrete-event",
    "event-driven",
    "framework",
    "typescript",
    "nodejs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mettiu88/simloop.git"
  },
  "homepage": "https://github.com/Mettiu88/simloop#readme",
  "bugs": {
    "url": "https://github.com/Mettiu88/simloop/issues"
  },
  "author": "Matteo Virgilio <mettiu_sicilia@hotmail.it> (https://www.matteovirgilio.it/)",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
